<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.typemaster.Main$TypeMasterController"
           styleClass="root-pane"
           prefWidth="820.0"
           prefHeight="620.0">

    <!-- HOME PANEL -->
    <VBox fx:id="homePane" visible="true" managed="${homePane.visible}" alignment="CENTER" spacing="30" styleClass="pane-container">
        <!-- Title and Logo -->
        <VBox alignment="CENTER" spacing="10">
            <Text text="TypeMaster" styleClass="title-text" />
            <Text text="Test and improve your typing speed with style" styleClass="subtitle-text" />
        </VBox>

        <!-- Difficulty Selection -->
        <VBox alignment="CENTER" spacing="15" styleClass="difficulty-section">
            <Text text="SELECT DIFFICULTY" styleClass="section-header" />
            <HBox alignment="CENTER" spacing="15">
                <ToggleButton fx:id="easyBtn" text="Easy" styleClass="difficulty-toggle" selected="true">
                    <toggleGroup>
                        <ToggleGroup fx:id="difficultyGroup" />
                    </toggleGroup>
                </ToggleButton>
                <ToggleButton fx:id="mediumBtn" text="Medium" styleClass="difficulty-toggle" toggleGroup="${difficultyGroup}" />
                <ToggleButton fx:id="hardBtn" text="Hard" styleClass="difficulty-toggle" toggleGroup="${difficultyGroup}" />
            </HBox>
        </VBox>

        <!-- Action Button -->
        <Button text="Start Typing Test" onAction="#handleStartTest" styleClass="action-button" />
    </VBox>

    <!-- TYPING TEST PANEL -->
    <VBox fx:id="testPane" visible="false" managed="${testPane.visible}" spacing="20" styleClass="pane-container">
        <!-- Minimal Header -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Text text="TypeMaster" styleClass="mini-title-text" />
            <Pane HBox.hgrow="ALWAYS" />
            <Text fx:id="difficultyLabel" text="EASY MODE" styleClass="mode-label" />
        </HBox>

        <!-- Stats Bar -->
        <HBox styleClass="stats-container">
            <VBox styleClass="stat-box">
                <Text fx:id="wpmText" text="0" styleClass="stat-value" />
                <Text text="WPM" styleClass="stat-label" />
            </VBox>
            <VBox styleClass="stat-box">
                <Text fx:id="accuracyText" text="100%" styleClass="stat-value" />
                <Text text="Accuracy" styleClass="stat-label" />
            </VBox>
            <VBox styleClass="stat-box">
                <Text fx:id="timeText" text="60" styleClass="stat-value" />
                <Text text="Seconds" styleClass="stat-label" />
            </VBox>
        </HBox>

        <!-- Typing Playground -->
        <StackPane styleClass="playground-container" VBox.vgrow="ALWAYS">
            <!-- Hidden input field to capture keys -->
            <TextField fx:id="hiddenInput" styleClass="hidden-input" />
            
            <!-- Interactive Card to type in -->
            <ScrollPane fx:id="scrollPane" styleClass="typing-card" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER">
                <TextFlow fx:id="textFlow" styleClass="typing-flow" />
            </ScrollPane>
        </StackPane>

        <!-- Navigation Buttons -->
        <HBox alignment="CENTER" spacing="20" styleClass="control-box">
            <Button text="Restart" onAction="#handleRestart" styleClass="secondary-button" />
            <Button text="Home" onAction="#handleGoHome" styleClass="secondary-button" />
        </HBox>
    </VBox>

    <!-- RESULTS PANEL -->
    <VBox fx:id="resultPane" visible="false" managed="${resultPane.visible}" alignment="CENTER" spacing="30" styleClass="pane-container">
        <!-- Header -->
        <VBox alignment="CENTER" spacing="10">
            <Text text="Test Completed!" styleClass="title-text-green" />
            <Text fx:id="feedbackText" text="Excellent typing!" styleClass="subtitle-text" />
        </VBox>

        <!-- Results Display Cards -->
        <HBox alignment="CENTER" spacing="30">
            <VBox styleClass="result-card">
                <Text fx:id="finalWpmText" text="72" styleClass="result-value-primary" />
                <Text text="Final WPM" styleClass="stat-label" />
            </VBox>
            <VBox styleClass="result-card">
                <Text fx:id="finalAccuracyText" text="98%" styleClass="result-value-secondary" />
                <Text text="Accuracy" styleClass="stat-label" />
            </VBox>
        </HBox>

        <!-- Stats Breakdown Summary -->
        <VBox alignment="CENTER" spacing="10" styleClass="stats-summary-box">
            <Text fx:id="summaryText" text="Raw Keystrokes: 350 | Correct: 340 | Errors: 10" styleClass="summary-text" />
        </VBox>

        <!-- Navigation Controls -->
        <HBox alignment="CENTER" spacing="20" styleClass="control-box">
            <Button text="Type Again" onAction="#handleRestart" styleClass="action-button" />
            <Button text="Go Home" onAction="#handleGoHome" styleClass="secondary-button" />
        </HBox>
    </VBox>

</StackPane>
